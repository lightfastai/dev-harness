{
  "$schema": "./node_modules/@lightfastai/dev-proxy/schema/config.schema.json",
  "portless": {
    "name": "mfe",
    "port": 1355,
    "https": false
  },
  "apps": {
    "app": {
      "packageName": "@example/app",
      "fallback": "https://app.example.com",
      "mfe": true
    },
    "www": {
      "packageName": "@example/www",
      "fallback": "https://www.example.com",
      "mfe": true
    },
    "platform": {
      "packageName": "@example/platform",
      "fallback": "https://platform.example.com",
      "mfe": false
    }
  },
  "microfrontends": {
    "config": "microfrontends.json"
  }
}
