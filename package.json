{
  "name": "dev-harness",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "pnpm --filter @lightfastai/dev-cli build",
    "dev": "lightfast-dev dev --mfe-app app --mfe-app www -- turbo run dev --ui=tui --filter=@example/app --filter=@example/www",
    "dev:apps": "pnpm dev",
    "predev:app": "pnpm --filter @lightfastai/dev-cli build",
    "dev:app": "lightfast-dev dev --mfe-app app -- turbo run dev --filter=@example/app",
    "predev:desktop": "pnpm --filter @lightfastai/dev-cli build",
    "dev:desktop": "pnpm --filter @example/desktop dev",
    "predev:www": "pnpm --filter @lightfastai/dev-cli build",
    "dev:www": "lightfast-dev dev --mfe-app www -- turbo run dev --filter=@example/www",
    "predev:setup": "pnpm --filter @lightfastai/dev-cli build",
    "dev:setup": "lightfast-dev setup && pnpm db:migrate",
    "predev:doctor": "pnpm --filter @lightfastai/dev-cli build",
    "dev:doctor": "lightfast-dev doctor --postgres-table example_probe_events",
    "premfe:url": "pnpm --filter @lightfastai/dev-cli build",
    "mfe:url": "lightfast-dev proxy url",
    "build": "turbo run build --filter='@lightfastai/dev-*'",
    "test": "turbo run test --filter='@lightfastai/dev-*'",
    "release:check": "turbo run typecheck test --filter='@lightfastai/dev-*' && pnpm changeset status",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "db:url": "lightfast-dev postgres url",
    "db:up": "lightfast-dev postgres up",
    "db:create": "lightfast-dev postgres create",
    "db:generate": "pnpm --filter @example/db-app db:generate",
    "db:migrate": "pnpm --filter @example/db-app db:migrate",
    "db:studio": "pnpm --filter @example/db-app db:studio",
    "redis:url": "lightfast-dev redis url",
    "redis:up": "lightfast-dev redis up",
    "redis:ping": "lightfast-dev redis ping",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@lightfastai/dev-cli": "workspace:*",
    "@lightfastai/dev-core": "workspace:*",
    "@lightfastai/dev-services": "workspace:*",
    "@lightfastai/dev-proxy": "workspace:*",
    "portless": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
