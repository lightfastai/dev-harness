{
  "name": "mfe-sandbox",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "pnpm --filter @lightfastai/dev-core build && pnpm --filter @lightfastai/related-projects build && pnpm --filter @lightfastai/dev-services build",
    "dev": "lightfast-dev-services inngest-sync --mfe-app app --mfe-app www -- portless-mfe turbo run dev --ui=tui --filter=app --filter=www",
    "dev:apps": "pnpm dev",
    "predev:app": "pnpm --filter @lightfastai/dev-core build && pnpm --filter @lightfastai/related-projects build && pnpm --filter @lightfastai/dev-services build",
    "dev:app": "lightfast-dev-services inngest-sync --mfe-app app -- portless-mfe turbo run dev --filter=app",
    "predev:desktop": "pnpm --filter @lightfastai/dev-core build && pnpm --filter @lightfastai/related-projects build",
    "dev:desktop": "pnpm --filter desktop dev",
    "predev:www": "pnpm --filter @lightfastai/dev-core build && pnpm --filter @lightfastai/related-projects build && pnpm --filter @lightfastai/dev-services build",
    "dev:www": "lightfast-dev-services inngest-sync --mfe-app www -- portless-mfe turbo run dev --filter=www",
    "premfe:url": "pnpm --filter @lightfastai/dev-core build && pnpm --filter @lightfastai/related-projects build",
    "mfe:url": "portless-mfe url",
    "dev-core:release:check": "pnpm --filter @lightfastai/dev-core run release:check",
    "dev-core:publish:dry-run": "pnpm --filter @lightfastai/dev-core run publish:dry-run",
    "dev-core:publish": "pnpm --filter @lightfastai/dev-core run publish:npm",
    "dev-services:release:check": "pnpm --filter @lightfastai/dev-services run release:check",
    "dev-services:publish:dry-run": "pnpm --filter @lightfastai/dev-services run publish:dry-run",
    "dev-services:publish": "pnpm --filter @lightfastai/dev-services run publish:npm",
    "related-projects:release:check": "pnpm --filter @lightfastai/related-projects run release:check",
    "related-projects:publish:dry-run": "pnpm --filter @lightfastai/related-projects run publish:dry-run",
    "related-projects:publish": "pnpm --filter @lightfastai/related-projects run publish:npm",
    "db:url": "lightfast-dev-services postgres-url --base-name mfe_sandbox",
    "db:up": "lightfast-dev-services postgres-up",
    "db:create": "lightfast-dev-services postgres-create --base-name mfe_sandbox",
    "redis:url": "lightfast-dev-services redis-url --base-name mfe_sandbox",
    "redis:up": "lightfast-dev-services redis-up --base-name mfe_sandbox",
    "redis:ping": "lightfast-dev-services redis-ping --base-name mfe_sandbox",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@lightfastai/dev-core": "workspace:*",
    "@lightfastai/dev-services": "workspace:*",
    "@lightfastai/related-projects": "workspace:*",
    "portless": "^0.12.0",
    "turbo": "~2.9.8",
    "typescript": "^5.0.0"
  }
}
