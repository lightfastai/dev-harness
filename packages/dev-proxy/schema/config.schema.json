{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lightfast.ai/schemas/dev-proxy/config.schema.json",
  "title": "Lightfast Dev Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["apps"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "portless": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "https": {
          "type": "boolean"
        },
        "tld": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "apps": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packageName", "mfe"],
        "properties": {
          "packageName": {
            "type": "string",
            "minLength": 1
          },
          "portlessName": {
            "type": "string",
            "minLength": 1
          },
          "fallback": {
            "type": "string",
            "format": "uri"
          },
          "mfe": {
            "type": "boolean"
          }
        }
      }
    },
    "microfrontends": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "config": {
          "type": "string",
          "minLength": 1
        },
        "proxyPortRange": {
          "$ref": "#/$defs/portRange"
        }
      }
    }
  },
  "$defs": {
    "portRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    }
  }
}
