{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo.local/portless-mfe-dev/config.schema.json",
  "title": "Portless MFE Dev Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "portless": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "https": {
          "type": "boolean"
        },
        "tld": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "microfrontends": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "config": {
          "type": "string",
          "minLength": 1
        },
        "apps": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "appPortRange": {
          "$ref": "#/$defs/portRange"
        },
        "proxyPortRange": {
          "$ref": "#/$defs/portRange"
        }
      }
    }
  },
  "$defs": {
    "portRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    }
  }
}
