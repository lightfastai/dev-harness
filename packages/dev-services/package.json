{
  "name": "@lightfastai/dev-services",
  "version": "0.1.2",
  "description": "Local development service helpers for Lightfast worktrees.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/public.js",
  "types": "./dist/public.d.ts",
  "sideEffects": false,
  "keywords": [
    "lightfast",
    "development",
    "worktrees",
    "inngest",
    "drizzle"
  ],
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "bin": {
    "lightfast-dev-services": "bin/lightfast-dev-services.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "rm -rf dist .turbo/test-dist *.tgz",
    "clean:dist": "rm -rf dist",
    "build": "pnpm --filter @lightfastai/dev-core build && tsc -p tsconfig.build.json",
    "prepack": "pnpm run clean:dist && pnpm run build",
    "pack:check": "pnpm run clean:dist && pnpm run build && node scripts/check-pack.mjs",
    "release:check": "pnpm run typecheck && pnpm run test && pnpm run pack:check",
    "prepublishOnly": "pnpm run release:check",
    "publish:dry-run": "pnpm publish --dry-run --access public --no-git-checks",
    "publish:npm": "pnpm publish --access public --no-git-checks",
    "test": "pnpm run build && rm -rf .turbo/test-dist && tsc -p tsconfig.test.json && node --test .turbo/test-dist/test/*.test.js",
    "typecheck": "pnpm --filter @lightfastai/dev-core build && tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@lightfastai/dev-core": "workspace:^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
