{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lightfast.ai/schemas/related-projects/config.schema.json",
  "title": "Lightfast Related Projects Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "portless": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "https": {
          "type": "boolean"
        },
        "tld": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "microfrontends": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "config": {
          "type": "string",
          "minLength": 1
        },
        "apps": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "dir": {
                    "type": "string",
                    "minLength": 1
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "portlessName": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            ]
          }
        },
        "proxyPortRange": {
          "$ref": "#/$defs/portRange"
        }
      }
    }
  },
  "$defs": {
    "portRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "max": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    }
  }
}
