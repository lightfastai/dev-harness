{
  "name": "@lightfastai/related-projects",
  "version": "0.0.0",
  "description": "Development helpers for Lightfast related projects using Vercel microfrontends and portless.",
  "license": "UNLICENSED",
  "type": "module",
  "files": [
    "bin",
    "dist",
    "schema",
    "README.md"
  ],
  "bin": {
    "portless-mfe": "bin/portless-mfe.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./related-projects": {
      "types": "./dist/related-projects.d.ts",
      "import": "./dist/related-projects.js"
    },
    "./schema/config.schema.json": "./schema/config.schema.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "rm -rf .turbo/test-dist && tsc -p tsconfig.test.json && node --test .turbo/test-dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@vercel/related-projects": "1.1.0",
    "portless": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
