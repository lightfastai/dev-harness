{
  "name": "@lightfastai/related-projects",
  "version": "0.1.3",
  "description": "Development helpers for Lightfast related projects using Vercel microfrontends and portless.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/public.js",
  "types": "./dist/public.d.ts",
  "sideEffects": false,
  "keywords": [
    "lightfast",
    "microfrontends",
    "portless",
    "vercel",
    "related-projects"
  ],
  "files": [
    "bin",
    "dist",
    "schema",
    "README.md"
  ],
  "bin": {
    "portless-mfe": "bin/portless-mfe.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./related-projects": {
      "types": "./dist/related-projects.d.ts",
      "import": "./dist/related-projects.js"
    },
    "./package.json": "./package.json",
    "./schema/config.schema.json": "./schema/config.schema.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "rm -rf dist .turbo/test-dist *.tgz",
    "clean:dist": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm run clean:dist && pnpm run build",
    "pack:check": "pnpm run clean:dist && pnpm run build && node scripts/check-pack.mjs",
    "release:check": "pnpm run typecheck && pnpm run test && pnpm run pack:check",
    "prepublishOnly": "pnpm run release:check",
    "publish:dry-run": "npm publish --dry-run",
    "publish:npm": "npm publish",
    "test": "pnpm run build && rm -rf .turbo/test-dist && tsc -p tsconfig.test.json && node --test .turbo/test-dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "portless": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
